@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

set(_YoloOrtDml_saved_CMAKE_PREFIX_PATH "${CMAKE_PREFIX_PATH}")
list(PREPEND CMAKE_PREFIX_PATH "${PACKAGE_PREFIX_DIR}")
find_dependency(OpenCV CONFIG REQUIRED COMPONENTS world)
set(CMAKE_PREFIX_PATH "${_YoloOrtDml_saved_CMAKE_PREFIX_PATH}")
unset(_YoloOrtDml_saved_CMAKE_PREFIX_PATH)

set_and_check(YoloOrtDml_RUNTIME_DIR "${PACKAGE_PREFIX_DIR}/bin")
set(YoloOrtDml_RUNTIME_DLLS "${YoloOrtDml_RUNTIME_DIR}/YoloOrtDml.dll")
if(EXISTS "${YoloOrtDml_RUNTIME_DIR}/DirectML.dll")
    list(APPEND YoloOrtDml_RUNTIME_DLLS "${YoloOrtDml_RUNTIME_DIR}/DirectML.dll")
endif()

include("${CMAKE_CURRENT_LIST_DIR}/YoloOrtDmlTargets.cmake")

check_required_components(YoloOrtDml)
